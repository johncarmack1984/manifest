# Manifest configuration. Copy to infra/.env and fill in.
# infra/.env is gitignored — your real values never get committed.

# --- Required ---
MANIFEST_DOMAIN_NAME=manifest.example.com        # public hostname for the dashboard
MANIFEST_HOSTED_ZONE_ID=Z0123456789ABCDEFGHIJ    # Route53 zone that owns the domain (aws route53 list-hosted-zones)
MANIFEST_HOSTED_ZONE_NAME=example.com            # the zone's name, no trailing dot
MANIFEST_COGNITO_DOMAIN_PREFIX=manifest-example  # <prefix>.auth.us-east-1.amazoncognito.com (must be globally unique)
MANIFEST_OWNER_EMAIL=you@example.com             # the single admin user created in the pool

# --- Optional (defaults shown) ---
# MANIFEST_NAME=manifest                          # base name for resources (Lambda, table, bucket prefix, tags)
# MANIFEST_INDEXED_REGIONS=us-east-1              # comma-separated; cost still covers ALL regions, this drives inventory
# MANIFEST_CACHE_TTL_SECONDS=3600                 # how long Cost Explorer responses are cached
# MANIFEST_CREATE_AGGREGATOR=false                # reuse an aggregator the account already has (else create one)
#
# Cross-account inventory: cost is org-wide (consolidated billing), but inventory is
# per-account, so the Lambda assumes a read role in each org member account. Deploy
# that role into each member with `AWS_PROFILE=<member> MANIFEST_PAYER_ACCOUNT=<payer>
# just member-deploy`. Set MANIFEST_MEMBER_ROLE="" to disable (this account only).
# MANIFEST_MEMBER_ROLE=ManifestInventoryRole      # role name assumed in each member account
# MANIFEST_PAYER_ACCOUNT=                          # payer/management account id (only for member-deploy)
#
# Sign in with AWS IAM Identity Center (SSO) instead of a Cognito password. Leave
# unset for standalone Cognito login (MANIFEST_OWNER_EMAIL is then ignored). To
# enable: deploy once, create an Identity Center customer-managed SAML app from the
# stack's SamlAcsUrl + SamlSpEntityId outputs, then set its metadata URL here and
# redeploy. See README → Authentication.
# MANIFEST_SAML_METADATA_URL=https://portal.sso.us-east-1.amazonaws.com/saml/metadata/abc123
